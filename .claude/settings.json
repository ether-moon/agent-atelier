{
  "permissions": {
    "allow": [
      "Bash(*/knowledge-gate:*)",
      "Bash(sqlite3 .knowledge/vault.db:*)",
      "Bash(*/on-prompt.sh)",
      "Bash(*/on-pre-tool-use.sh)",
      "Bash(*/on-task-completed.sh)",
      "Bash(*/on-stop.sh)",
      "Bash(*/state-commit:*)",
      "Bash(*/build-vrm-prompt:*)"
    ]
  },
  "enabledPlugins": {
    "agent-atelier@agent-atelier": true,
    "skill-set": true,
    "knowledge-distillery@knowledge-distillery": true
  },
  "extraKnownMarketplaces": {
    "agent-atelier": {
      "source": {
        "source": "github",
        "repo": "ether-moon/agent-atelier"
      },
      "autoUpdate": true
    },
    "skill-set": {
      "source": {
        "source": "github",
        "repo": "ether-moon/skill-set"
      },
      "autoUpdate": true
    },
    "knowledge-distillery": {
      "source": {
        "source": "github",
        "repo": "ether-moon/knowledge-distillery"
      },
      "autoUpdate": true
    }
  }
}
